                    "config": {
                        "html": "<div class=\"listing-group\">\n\n\n<div class=\"listing\">\n<div class=\"listing__content\">\n<div class=\"listing__badges\">\n<span class=\"badge\">Licitation</span>\n<span class=\"listing__location\">København V</span>\n</div>\n<h3 class=\"listing__title\">Selvstændigt baghus</h3>\n<p class=\"listing__quote\">\"En lille perle på en super beliggenhed. Perfekt til konvertering.\"</p>\n<div class=\"listing__features\">\n<div class=\"listing__feature\">Ca. 110 m²</div>\n<div class=\"listing__feature\">Renoveringsprojekt</div>\n<div class=\"listing__feature\">Central Beliggenhed</div>\n</div>\n<div class=\"listing__footer\">\n<p class=\"listing__price\">Pris + 5 mio. kr.</p>\n<a href=\"/kontakt-os\" class=\"link\">Hør mere om sagen</a>\n</div>\n</div>\n<div class=\"listing__image\">\n<img src=\"https://mediaserver.prod.realequity.dk/images/8a635a2a-fc80-472c-8bc7-bc6bfe1e26f0/baghus-Large/lg\" alt=\"Baghus København V\" />\n</div>\n</div>\n\n\n<!--<div class=\"listing listing--reverse\">\n<div class=\"listing__content\">\n<div class=\"listing__badges\">\n<span class=\"badge\" style=\"background:#c19a5b;\">Solgt / Handlet</span>\n<span class=\"listing__location\">København V</span>\n</div>\n<h3 class=\"listing__title\">Øverste 2 etager i baghus</h3>\n<p class=\"listing__quote\">\"Hele baghuset er gennemrenoveret og istandsat. Stor altan og egen parkering.\"</p>\n<div class=\"listing__features\">\n<div class=\"listing__feature\">+170 m² bolig</div>\n<div class=\"listing__feature\">Stor privat altan</div>\n<div class=\"listing__feature\">P-plads (Lejet)</div>\n<div class=\"listing__feature\">Totalrenoveret</div>\n</div>\n<div class=\"listing__footer\">\n<p class=\"listing__price\">14 mio. kr.</p>\n<a href=\"/kontakt-os\" class=\"link\">Hør mere om sagen</a>\n</div>\n</div>\n<div class=\"listing__image\">\n<img src=\"https://images.unsplash.com/photo-1600607686527-6fb886090705?q=80&w=2000&auto=format&fit=crop\" alt=\"København V Renoveret\" />\n</div>\n</div>-->\n\n\n<div class=\"listing\">\n<div class=\"listing__content\">\n<div class=\"listing__badges\">\n<span class=\"badge\">Fredet</span>\n<span class=\"listing__location\">København K</span>\n</div>\n<h3 class=\"listing__title\">Unikt konverteringsprojekt</h3>\n<p class=\"listing__quote\">\"4 lejligheder i fredet ejendom. Mulighed for sammenlægning til 1 eller 2 store enheder.\"</p>\n<div class=\"listing__features\">\n<div class=\"listing__feature\">Ialt 284 m²</div>\n<div class=\"listing__feature\">Charmerende gårdanlæg</div>\n<div class=\"listing__feature\">Blandet bolig/erhverv</div>\n<div class=\"listing__feature\">4 min til Metro</div>\n</div>\n<div class=\"listing__footer\">\n<div>\n<p class=\"listing__price\">10 mio. kr.</p>\n<span class=\"listing__price-note\">ca. 35.000 kr./m²</span>\n</div>\n<a href=\"/kontakt-os\" class=\"link\">Hør mere om sagen</a>\n</div>\n</div>\n<div class=\"listing__image\">\n<img src=\"https://mediaserver.prod.realequity.dk/images/5be66dfb-36a7-4493-bc2e-34b0de4ac095/livingrooom/lg\" alt=\"København K Fredet\" />\n</div>\n</div>\n\n\n<div class=\"listing listing--reverse\">\n<div class=\"listing__content\">\n<div class=\"listing__badges\">\n<span class=\"listing__location listing__location--first\">København V</span>\n</div>\n<h3 class=\"listing__title\">Penthouse m. privat tagterrasse</h3>\n<p class=\"listing__quote\">\"Fuldstændig istandsat penthouse i markant ejendom med elevator. Overvældende stilhed på toppen.\"</p>\n<div class=\"listing__features\">\n<div class=\"listing__feature\">+140 m² bolig</div>\n<div class=\"listing__feature\">45 m² privat tagterrasse</div>\n<div class=\"listing__feature\">Elevator &amp; Parkering</div>\n<div class=\"listing__feature\">Ugenert</div>\n</div>\n<div class=\"listing__footer\">\n<p class=\"listing__price\">17,5 mio. kr.</p>\n<a href=\"/kontakt-os\" class=\"link\">Hør mere om sagen</a>\n</div>\n</div>\n<div class=\"listing__image\">\n<img src=\"https://mediaserver.prod.realequity.dk/images/80fb6cec-3f2e-4ed1-b4f1-200ddcbce704/penthouse Large/lg\" alt=\"Penthouse København V\" />\n</div>\n</div>\n\n\n<div class=\"listing\">\n<div class=\"listing__content\">\n<div class=\"listing__badges\">\n<span class=\"listing__location listing__location--first\">Nykøbing Sjælland</span>\n</div>\n<h3 class=\"listing__title\">Rummelig familievilla</h3>\n<p class=\"listing__quote\">\"Diskret udbud – en bolig hvor plads, kvalitet og beliggenhed går op i en højere enhed.\"</p>\n<div class=\"listing__features\">\n<div class=\"listing__feature\">211 m² bolig</div>\n<div class=\"listing__feature\">1.750 m² grund</div>\n<div class=\"listing__feature\">5 værelser</div>\n<div class=\"listing__feature\">80 m² træterrasse</div>\n</div>\n<div class=\"listing__footer\">\n<p class=\"listing__price\">3,195 mio. kr.</p>\n<a href=\"/kontakt-os\" class=\"link\">Hør mere om sagen</a>\n</div>\n</div>\n<div class=\"listing__image\">\n<img src=\"https://mediaserver.prod.realequity.dk/images/48f2d113-28af-43d0-90d6-6e6ee6dbd4c5/interioe/lg\" alt=\"Villa Nykøbing Sjælland\" />\n</div>\n</div>\n\n</div>"
