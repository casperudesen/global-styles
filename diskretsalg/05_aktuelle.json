                    "width": "100%",
                    "config": {
                        "html": "<style>/* Scoped Styles for Listings - FIXED OVERLAP BUG */.listing-group { display: flex; flex-direction: column; gap: 4rem; max-width: 1000px; margin: 0 auto; }.listing { display: grid; grid-template-columns: 1fr; background: #fff; border-radius: 4px; overflow: hidden; width: 100%; box-shadow: 0 4px 20px rgba(0,0,0,0.06); }.listing__image { position: relative; width: 100%; height: 300px; overflow: hidden; }.listing__image img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }.listing:hover .listing__image img { transform: scale(1.03); }.listing__content { padding: 2rem; display: flex; flex-direction: column; gap: 1rem; position: relative; z-index: 2; /* Ensure text sits above if any conflict */ }.listing__badges { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem; }.badge { background: #11352f; color: #fff; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; padding: 4px 10px; font-weight: 600; border-radius: 2px; }.listing__location { color: #c19a5b; font-weight: 700; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em; }.listing__title { font-family: 'Playfair Display', serif; font-size: 1.75rem; color: #11352f; margin: 0; line-height: 1.2; }.listing__quote { font-family: 'DM Sans', sans-serif; font-style: italic; color: #666; font-size: 1rem; line-height: 1.5; }.listing__features { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 1rem; }.listing__feature { font-size: 0.85rem; color: #444; background: #f9f9f9; padding: 4px 12px; border-radius: 50px; border: 1px solid #eee; }.listing__footer { margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid #eee; display: flex; justify-content: space-between; align-items: center; }.listing__price { font-family: 'Playfair Display', serif; font-size: 1.5rem; color: #11352f; font-weight: 600; margin: 0; }.listing__price-note { font-size: 0.8rem; color: #888; display: block; }.link { color: #c19a5b; text-decoration: none; font-weight: 600; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; transition: color 0.3s; }.link:hover { color: #11352f; }@media (min-width: 900px) { .listing { /* FIX: repeat(2, minmax(0, 1fr)) prevents columns from blowing out/overlapping */ grid-template-columns: repeat(2, minmax(0, 1fr)); align-items: stretch; } .listing__image { height: auto; min-height: 100%; } .listing--reverse .listing__image { order: 1; } .listing--reverse .listing__content { order: 2; } }</style><div class=\"text-center\" style=\"margin-bottom:3rem;\">\n<span class=\"tag\">Eksklusivt</span>\n<h2 class=\"title title--xl title--center\">Aktuelle Skuffesager</h2>\n<p class=\"text text--center max-w-lg mx-auto\">Udvalgte ejendomme der kun udbydes diskret. Kontakt os for yderligere information og fremvisning.</p>\n</div>"
