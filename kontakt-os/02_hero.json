                        "html": "<style>\n:root {\n  --c-hero-overlay: rgba(17, 53, 47, 0.7);\n  --c-hero-text: #ffffff;\n  --c-hero-subtext: rgba(255, 255, 255, 0.9);\n}\n\n.hero-image-contact {\n  position: relative;\n}\n\n.hero-image-contact::before {\n  content: \"\";\n  position: absolute;\n  inset: 0;\n  background-color: var(--c-primary);\n  opacity: 0.7;\n  mix-blend-mode: multiply;\n  pointer-events: none;\n  z-index: 1;\n}\n\n.hero-image-contact::after {\n  content: \"\";\n  position: absolute;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  height: 8rem;\n  background: linear-gradient(to top, var(--c-white), transparent);\n  pointer-events: none;\n  z-index: 2;\n}\n\n.hero-image-contact > * {\n  position: relative;\n  z-index: 3;\n}\n\n.hero-tag {\n  color: var(--c-accent);\n  text-transform: uppercase;\n  letter-spacing: 0.2em;\n  font-weight: 600;\n  display: block;\n}\n\n.hero-title {\n  font-family: var(--f-serif);\n  color: var(--c-hero-text);\n  margin: 0 0 1rem 0;\n  font-size: clamp(2.5rem, 5vw, 4.5rem);\n}\n\n.hero-subtitle {\n  font-family: var(--f-sans);\n  font-weight: 300;\n  max-width: 42rem;\n  margin: 0 auto;\n  color: var(--c-hero-subtext);\n}\n</style>"
