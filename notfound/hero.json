                    "config": {
                        "html": "<div class=\"fb-hero-content text-center\" style=\"z-index: 10; position: relative;\"><div class=\"inline-block mb-6\"><span class=\"section-label\" style=\"border-bottom: 1px solid rgba(193, 154, 91, 0.4); padding-bottom: 8px; color: var(--c-accent); text-transform: uppercase; letter-spacing: 0.3em; font-size: 14px; font-weight: 700;\">Fejl 404</span></div><h1 class=\"hero-title fb-visible\" style=\"font-size: clamp(3rem, 10vw, 6rem); margin-bottom: 30px; line-height: 1.1; color: white;\">Siden blev ikke <br><span class=\"accent italic\" style=\"color: var(--c-accent);\">fundet</span></h1><p class=\"hero-subtitle fb-visible\" style=\"max-width: 550px; margin: 0 auto 40px; color: rgba(255,255,255,0.7); font-size: 1.25rem;\">Det ser ud til, at du er faret vild blandt boligerne. Fortvivl ej, vi hjælper dig gerne tilbage på rette vej.</p><div class=\"hero-buttons fb-visible\"><a href=\"/\" class=\"hero-btn hero-btn--primary\">Gå til forsiden</a><a href=\"/kontakt-os\" class=\"hero-btn hero-btn--secondary\">Kontakt os</a></div></div><div style=\"position: absolute; bottom: 40px; left: 0; right: 0; z-index: 10; text-align: center; opacity: 0.3; pointer-events: none;\"><p style=\"text-transform: uppercase; letter-spacing: 0.5em; font-size: 10px; color: white;\">Eksklusiv Ejendomsformidling</p></div><div class=\"fb-hero-overlay\"></div><style>.fb-hero-overlay { position: absolute; inset: 0; background: linear-gradient(rgba(17, 53, 47, 0.7), rgba(17, 53, 47, 0.85)); z-index: 1; } .hero-btn { display: inline-flex; align-items: center; justify-content: center; min-width: 200px; padding: 18px 32px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.2em; font-size: 12px; transition: all 0.3s ease; text-decoration: none; border-radius: 2px; } .hero-btn--primary { background: var(--c-accent); color: var(--c-primary); } .hero-btn--primary:hover { background: var(--c-accent-hover); transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.2); } .hero-btn--secondary { border: 1px solid rgba(255,255,255,0.3); color: white; margin-left: 20px; } .hero-btn--secondary:hover { border-color: white; background: rgba(255,255,255,0.1); } @media (max-width: 640px) { .hero-btn--secondary { margin-left: 0; margin-top: 15px; } }</style>"
