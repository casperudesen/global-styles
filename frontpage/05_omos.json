                                    }
                                },
                                {
                                    "type": "TypographyComponent",
                                    "id": "component_fc3d2f1c_34dc_4790_8698_a60bab7ef13c",
                                    "config": {
                                        "text": "<p class='section-body'>Steffen Falch &amp; Jannik Bai kender hinanden gennem fælles bekendte i ejendomsbranchen. Vi har fundet fælles fodslag i vores passion, nemlig ejendomme.</p>",
                                        "size": "md",
                                        "textColor": "var(--page-text-color)"
                                    }
                                },
                                {
                                    "type": "TypographyComponent",
                                    "id": "component_7a4c9afd_13b1_4ceb_9d13_7f0bf799224d",
                                    "config": {
                                        "text": "<p class='section-body'>Med over 30 års samlet erfaring tilbyder vi enestående indsigt i markedet i København og Nordsjælland. Vi kombinerer klassiske dyder med moderne salgsmetoder for at sikre dig det bedste resultat.</p>",
                                        "size": "md",
