                                "html": "<div style='background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.12);padding:2rem;height:100%;'><h3 style='font-family:\"Playfair Display\",serif;font-size:1.25rem;color:#c19a5b;margin-bottom:0.75rem;'>Langgade-kvarteret</h3><p style='font-family:\"DM Sans\",sans-serif;font-size:0.9375rem;color:rgba(255,255,255,0.8);line-height:1.7;'>Omkring Valby Langgade finder du villaer, rækkehuse og små sidegader med en nærmest landsbyagtig stemning, tæt på butiksliv og station.</p></div>"
                            }
                        },
                        {
